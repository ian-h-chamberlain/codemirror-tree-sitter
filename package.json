{
  "name": "codemirror-lang-nushell",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Nushell language support for CodeMirror",
  "scripts": {
    "clean": "bun ./build clean",
    "clean:modules": "bun install --force && bun clean",
    "dist": "bun pm pack",
    "lint": "tsc --build && eslint",
    "make": "bun ./build",
    "make:clean": "bun clean && bun make",
    "postinstall": "cd node_modules/tree-sitter-nu && tree-sitter build --wasm || true",
    "prepack": "NODE_ENV=production bun make:clean",
    "serve": "bun make && bun --watch ./demo/index.html",
    "serve:clean": "bun clean && bun serve",
    "test": "bun make && mocha test/test.js"
  },
  "type": "module",
  "Module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js"
  },
  "types": "dist/index.d.ts",
  "sideEffects": [
    "demo/*"
  ],
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.17",
    "@fsegurai/codemirror-theme-monokai": "^6.2.3",
    "@fsegurai/codemirror-theme-tokyo-night-day": "^6.2.3",
    "@lezer/highlight": "^1.0.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@types/bun": "^1.3.10",
    "web-tree-sitter": "^0.26.6"
  },
  "devDependencies": {
    "jiti": "^2.6.1",
    "@eslint/js": "^10.0.1",
    "@lezer/generator": "^1.0.0",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^24.1.0",
    "codemirror": "^6.0.2",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "mocha": "^11.7.1",
    "tree-sitter-cli": "^0.26.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1"
  },
  "optionalDependencies": {
    "tree-sitter-nu": "nushell/tree-sitter-nu"
  }
}
