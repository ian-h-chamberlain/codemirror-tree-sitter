{
  "name": "codemirror-lang-nushell",
  "version": "0.1.0",
  "description": "Nushell language support for CodeMirror",
  "scripts": {
    "build": "tsc --project tsconfig.build.json && ./esbuild.config.ts",
    "clean": "rm -rf dist public",
    "clean-build": "npm run clean && npm run build",
    "clean-serve": "npm run clean && npm run serve",
    "prepack": "npm run lint && BUILD=production npm run clean-build",
    "serve": "./esbuild.config.ts serve",
    "test": "npm run lint && mocha test/test.js",
    "lint": "tsc --project tsconfig.json",
    "watch": "./esbuild.config.ts watch"
  },
  "type": "module",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js"
  },
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@codemirror/language": "^6.0.0",
    "@lezer/highlight": "^1.0.0",
    "@lumis-sh/wasm-nushell": "^0.0.1-rev.bb3f533e",
    "web-tree-sitter": "^0.26.6"
  },
  "devDependencies": {
    "@lezer/generator": "^1.0.0",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^24.1.0",
    "codemirror": "^6.0.2",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.1",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
