{
  "name": "codemirror-lang-nushell",
  "version": "0.1.0",
  "description": "Nushell language support for CodeMirror",
  "scripts": {
    "clean": "rm -rf dist/ public/ *.tgz",
    "clean-build": "bun clean && bun make",
    "clean-serve": "bun clean && bun serve",
    "dist": "bun pm pack",
    "make": "bun ./build",
    "prepack": "bun clean && bun tsc && NODE_ENV=production bun make",
    "serve": "bun ./demo/index.html",
    "test": "bun tsc && mocha test/test.js",
    "tsc": "tsc --project tsconfig.json && tsc --project tsconfig.dist.json"
  },
  "type": "module",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js"
  },
  "types": "dist/index.d.ts",
  "sideEffects": [
    "demo/*"
  ],
  "dependencies": {
    "@codemirror/language": "^6.0.0",
    "@lezer/highlight": "^1.0.0",
    "@lumis-sh/wasm-nushell": "^0.0.1-rev.bb3f533e",
    "@types/bun": "^1.3.10",
    "web-tree-sitter": "^0.26.6"
  },
  "devDependencies": {
    "@lezer/generator": "^1.0.0",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^24.1.0",
    "codemirror": "^6.0.2",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.1",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
