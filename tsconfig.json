{
  "compilerOptions": {
    "strict": true,
    "target": "es2017",
    "module": "es2022",
    "lib": ["ES2024.Promise", "DOM"],
    "newLine": "lf",
    "moduleResolution": "node",
    "noEmit": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "dist",
  },
  "include": ["src/**/*.ts", "demo/*.ts", "esbuild.config.ts"],
}
